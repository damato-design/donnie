# Site Configuration
# Copy this file to .env and fill in your values

# Required: Your site URL (used for sitemap, canonical URLs, OG tags)
SITE_URL=https://donnie.damato.design

# Site language (ISO 639-1 code, e.g., en, id, de, fr, es, ja, zh)
SITE_LANGUAGE=en

# Personal Information
SITE_AUTHOR_NAME="Donnie D'Amato"
SITE_AUTHOR_TITLE="Design Systems Architect"
SITE_AUTHOR_BIO="Design Systems Architect based in New York and author of Mise en Mode. I began as an artist making creative interactions and, after two decades of writing code, found my purpose: to build great systems and pass the knowledge on to others."
SITE_AUTHOR_EMAIL=donnie@damato.design
SITE_AUTHOR_LOCATION="New York, NY"

# Social Links (leave empty to hide)
SOCIAL_GITHUB=https://github.com/fauxserious
SOCIAL_LINKEDIN=https://linkedin.com/in/fauxserious
SOCIAL_TWITTER=
SOCIAL_MASTODON=https://mastodon.social/@donniedamato
SOCIAL_BLUESKY=https://bsky.app/profile/donnie.damato.design

# Site Metadata
SITE_TITLE="Donnie D'Amato"
SITE_DESCRIPTION="Design Systems Architect based in New York, author of Mise en Mode, and international speaker bridging design and engineering with scalable, token-driven systems."
