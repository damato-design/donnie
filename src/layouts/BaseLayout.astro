---
/**
 * BaseLayout
 *
 * Foundation layout component that provides the core HTML structure,
 * navigation, footer, and global styles for all pages. All other layouts extend
 * this base layout to ensure consistent site-wide structure.
 *
 * Features:
 * - HTML document structure
 * - Favicon and manifest configuration
 * - Astro View Transitions support
 * - Sticky navigation header
 * - Global CSS imports (global, typography, cards)
 * - Responsive layout structure
 *
 * Note: SEO meta tags (title, description, OG, Twitter) should be handled
 * by the SEO component in each page, not in this layout.
 *
 * @component
 *
 * @example
 * ```astro
 * ---
 * import BaseLayout from '@layouts/BaseLayout.astro';
 * import SEO from '@components/SEO.astro';
 * ---
 *
 * <BaseLayout>
 *   <SEO
 *     slot="head"
 *     title="About Me"
 *     description="Learn more about my background"
 *   />
 *   <div>Page content goes here</div>
 * </BaseLayout>
 * ```
 */

import { ClientRouter } from "astro:transitions";
import Navigation from "@components/Navigation.astro";
import Footer from "@components/Footer.astro";
import LongShadow from "@components/LongShadow.astro";
import { siteConfig } from "../config";
import "@styles/global.css";
---

<!doctype html>
<html lang={siteConfig.language} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO tags injected via slot -->
    <slot name="head" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Font imports -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=BBH+Hegarty&family=LINE+Seed+JP&display=swap" rel="stylesheet">

    <ClientRouter />

    <script>
      /**
       * Kick autoplay videos into playing after every page load, including the
       * client-side navigations driven by <ClientRouter /> (View Transitions).
       *
       * On a real page load the browser autoplays a muted <video autoplay> as
       * it parses it. But when the ClientRouter swaps a freshly-fetched page
       * into the live document, that video node is *inserted* rather than
       * parsed, so the browser neither starts its autoplay nor, in many cases,
       * begins fetching the source at all, the media stays blank until a manual
       * refresh. This listener lives on `document` (which survives every swap),
       * so it is attached once and runs on each navigation: it forces an
       * unstarted source to load, then plays.
       */
      function playAutoplayVideos() {
        document
          .querySelectorAll<HTMLVideoElement>('video[autoplay]')
          .forEach((video) => {
            if (!video.paused) return;
            if (video.readyState === 0) video.load();
            video.play().catch(() => {});
          });
      }

      document.addEventListener('astro:page-load', playAutoplayVideos);
    </script>

    <script is:inline defer src="https://scripts.withcabin.com/hello.js"></script>

    <style>
      main {
        flex: 1;
        max-width: min(800px, 100%);
        margin: 0 auto;
        padding: 16px;
        overflow: hidden;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 1;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <Navigation />
    </header>
    <main id="top">
      <slot />
    </main>
    <Footer />
    <svg width="0" height="0"><LongShadow /></svg>
  </body>
</html>
