---
/**
 * Contact Page
 *
 * Minimal, intentional contact page with clear visual hierarchy and zone-based layout.
 * Prioritizes booking a call as the primary contact method, with social channels as the
 * secondary path. Email is intentionally not surfaced here.
 *
 * Layout Structure:
 * - Zone 1 (Primary): Cal.com booking CTA
 * - Zone 2 (Secondary): Social media links (only shown if configured)
 *
 * Features:
 * - Clean, distraction-free design
 * - Prominent "book a call" CTA
 * - Automatic filtering of configured social links
 * - Responsive layout
 * - Clear visual hierarchy
 *
 * Route: /contact
 *
 * @page
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import SEO from "@components/SEO.astro";
import Hero from "@components/Hero.astro";
import Typography from "@components/Typography.astro";
import Button from "@components/Button.astro";
import ButtonGroup from "@components/ButtonGroup.astro";
import { siteConfig } from "../config";
import { pagesConfig } from "../pages.config";

/**
 * Filters and formats social links from site configuration
 *
 * Only includes platforms that have a URL configured (non-empty values).
 * Capitalizes platform names for display (e.g., "github" becomes "Github").
 *
 * @returns Array of social link objects with platform name and URL
 */
const socialLinks = Object.entries(siteConfig.social)
  .filter(([_, url]) => url)
  .map(([platform, url]) => ({
    platform: platform.charAt(0).toUpperCase() + platform.slice(1),
    url,
  }));
---

<BaseLayout>
  <SEO
    slot="head"
    title={pagesConfig.contact.title}
    description={pagesConfig.contact.description}
    type="website"
  />

  <!-- Zone 1: Book a call (primary) -->
  <Hero>
    <Typography tagName="h2"
      >Prefer to talk it through? <em>Book a time</em></Typography
    >
    <Typography tagName="p"
      >Grab a slot on my calendar and let's talk design systems, theming, or
      whatever you're working on.</Typography
    >
    <ButtonGroup>
      <Button href="https://cal.com/donnie-damato" variant="primary" external
        >Book on Cal.com</Button
      >
    </ButtonGroup>
  </Hero>

  <!-- Page header -->
  <header class="primary-zone">
    <Typography tagName="h1">{pagesConfig.contact.heading}</Typography>
    <Typography tagName="p">
      The best way to reach me is to grab a slot on my calendar, or find me on
      the channels below.
    </Typography>
  </header>

  <!-- Zone 2: Secondary (Social) -->
  {
    socialLinks.length > 0 && (
      <section class="secondary-zone">
        <Typography tagName="h2">Elsewhere</Typography>
        <ul class="social-links">
          {socialLinks.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.platform}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .primary-zone {
    margin-bottom: 3rem;
  }

  .secondary-zone {
    padding-top: 3rem;
    border-top: 1px solid currentColor;
  }

  .social-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .social-links li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Decorative separator between social links (was an inline span). */
  .social-links li:not(:first-child)::before {
    content: "·";
    user-select: none;
  }
</style>
