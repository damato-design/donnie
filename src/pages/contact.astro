---
/**
 * Contact Page
 * 
 * Minimal, intentional contact page with clear visual hierarchy and zone-based layout.
 * Prioritizes email as the primary contact method while providing secondary social links.
 * 
 * Layout Structure:
 * - Zone 1 (Primary): Email address with context about response time
 * - Zone 2 (Secondary): Social media links (only shown if configured)
 * 
 * Features:
 * - Clean, distraction-free design
 * - Large, prominent email link
 * - Automatic filtering of configured social links
 * - Responsive layout
 * - Clear visual hierarchy
 * 
 * Route: /contact
 * 
 * @page
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import SEO from '@components/SEO.astro';
import Hero from '@components/Hero.astro';
import Typography from '@components/Typography.astro';
import Button from '@components/Button.astro';
import { siteConfig } from '../config';
import { pagesConfig } from '../pages.config';

/**
 * Filters and formats social links from site configuration
 * 
 * Only includes platforms that have a URL configured (non-empty values).
 * Capitalizes platform names for display (e.g., "github" becomes "Github").
 * 
 * @returns Array of social link objects with platform name and URL
 */
const socialLinks = Object.entries(siteConfig.social)
  .filter(([_, url]) => url)
  .map(([platform, url]) => ({
    platform: platform.charAt(0).toUpperCase() + platform.slice(1),
    url
  }));
---

<BaseLayout>
  <SEO 
    slot="head"
    title={pagesConfig.contact.title}
    description={pagesConfig.contact.description}
    type="website"
  />

  <main class="contact-page">
    <!-- Zone 1: Book a call -->
    <Hero compact>
      <Typography tagName="h2">Prefer to talk it through? <em>Book a time</em></Typography>
      <Typography tagName="p" size="lg" variant="secondary">Grab a slot on my calendar and let's talk design systems, theming, or whatever you're working on.</Typography>
      <div class="hero-cta">
        <Button href="https://cal.com/donnie-damato" variant="primary" external>Book on Cal.com</Button>
      </div>
    </Hero>

    <!-- Zone 2: Primary Intent -->
    <section class="primary-zone">
      <Typography tagName="h1" size="lg" variant="muted">{pagesConfig.contact.heading}</Typography>
      <a href={`mailto:${siteConfig.author.email}`} class="email-link">
        {siteConfig.author.email}
      </a>
      <Typography tagName="p" variant="muted">
        I read every email. Expect a reply within a few days.
      </Typography>
    </section>

    <!-- Zone 3: Secondary (Social) -->
    {socialLinks.length > 0 && (
      <section class="secondary-zone">
        <Typography tagName="h2" size="sm" variant="muted">Elsewhere</Typography>
        <div class="social-links">
          {socialLinks.map((link, index) => (
            <>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.platform}
              </a>
              {index < socialLinks.length - 1 && <Typography tagName="span" variant="muted" class="separator">·</Typography>}
            </>
          ))}
        </div>
      </section>
    )}
  </main>

  <style>
    .contact-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 1.5rem 8rem;
    }

    .primary-zone {
      margin-bottom: 3rem;
    }

    .email-link {
      display: block;
      font-size: clamp(1.75rem, 5vw, 2.5rem);
      
      color: var(--color-text);
      text-decoration: none;
      
      margin-bottom: 1.5rem;
      transition: color 0.2s ease;
    }

    .secondary-zone {
      padding-top: 3rem;
      border-top: 1px solid currentColor;
    }

    .social-links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }

    .separator {
      user-select: none;
    }

  </style>
</BaseLayout>
