---
/**
 * Writing Index Page with Pagination
 * 
 * Lists all published articles (excluding drafts) with pagination support. Displays
 * article cards with title, description, publish date, and tags. Uses a rest parameter
 * route to handle both the first page (/writing) and subsequent pages (/writing/2, etc.).
 * 
 * Features:
 * - Filters out draft articles (only shows published content)
 * - Sorts by publish date (descending - newest first)
 * - Pagination with 5 articles per page
 * - Dynamic page statistics showing current range
 * - SEO optimization per page
 * - Empty state handling
 * 
 * Routes:
 * - /writing (page 1)
 * - /writing/2 (page 2)
 * - /writing/3 (page 3)
 * - etc.
 * 
 * @page
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import SEO from '@components/SEO.astro';
import Pagination from '@components/Pagination.astro';
import Card from '@components/Card.astro';
import CardCta from '@components/CardCta.astro';
import TagList from '@components/TagList.astro';
import PageStats from '@components/PageStats.astro';
import Hero from '@components/Hero.astro';
import HeroPlaceholder from '@components/HeroPlaceholder.astro';
import Typography from '@components/Typography.astro';
import Button from '@components/Button.astro';
import { getCollection } from 'astro:content';
import { formatLongDate } from '@utils/formatDate';
import { pagesConfig } from '../../pages.config';
import type { GetStaticPaths } from 'astro';

/**
 * Generates static paths for all paginated pages
 * 
 * Queries published articles (draft: false), sorts by date, and creates
 * pagination paths. Page 1 uses undefined param to match /writing route,
 * while subsequent pages use numeric params (/writing/2, /writing/3, etc.).
 * 
 * @returns Array of path objects with params and props for each page
 */
export const getStaticPaths: GetStaticPaths = async () => {
  const postsPerPage = 5;
  
  const allArticles = await getCollection('writing');

  // Sort by publishDate (descending - most recent first)
  const sortedArticles = allArticles.sort((a, b) => {
    return b.data.publishDate.getTime() - a.data.publishDate.getTime();
  });

  const totalPages = Math.ceil(sortedArticles.length / postsPerPage);

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1;
    const start = i * postsPerPage;
    const end = start + postsPerPage;
    
    return {
      params: { page: page === 1 ? undefined : String(page) },
      props: {
        articles: sortedArticles.slice(start, end),
        currentPage: page,
        totalPages,
        totalArticles: sortedArticles.length,
      },
    };
  });
};

interface Props {
  /** Articles for the current page */
  articles: Awaited<ReturnType<typeof getCollection<'writing'>>>;
  
  /** Current page number (1-indexed) */
  currentPage: number;
  
  /** Total number of pages */
  totalPages: number;
  
  /** Total count of all published articles */
  totalArticles: number;
}

const { articles, currentPage, totalPages, totalArticles } = Astro.props;
const postsPerPage = 5;

/**
 * Generates page title based on current page number
 * 
 * Page 1 shows the main title, subsequent pages include page number.
 */
const pageTitle = currentPage === 1 
  ? pagesConfig.writing.title
  : `${pagesConfig.writing.title} - Page ${currentPage}`;
---

<BaseLayout>
  <SEO 
    slot="head"
    title={pageTitle}
    description={pagesConfig.writing.description}
    type="website"
  />

  <main class="page-container">
    {currentPage === 1 && (
      <Hero compact>
        <Typography tagName="h2">Now in print: <em>Mise en Mode</em></Typography>
        <Typography tagName="p" size="lg" variant="secondary">My book on rebuilding design token architecture from first principles. Stop adding tokens, start expressing modes.</Typography>
        <div class="hero-cta">
          <Button href="https://mode.place" variant="primary" external>Read the book</Button>
        </div>
        <HeroPlaceholder slot="aside" />
      </Hero>
    )}

    <header class="page-header">
      <Typography tagName="h1">{pagesConfig.writing.heading}</Typography>
      <Typography tagName="p" variant="secondary">{pagesConfig.writing.intro}</Typography>
      <PageStats text={totalPages > 1
        ? `Showing ${(currentPage - 1) * postsPerPage + 1}–${Math.min(currentPage * postsPerPage, totalArticles)} of ${totalArticles} articles`
        : `${totalArticles} articles`
      } />
    </header>

    {articles.length > 0 ? (
      <div class="card-list">
        {articles.map((article) => (
          <Card>
            <Fragment slot="meta">{formatLongDate(article.data.publishDate)}</Fragment>
            <Fragment slot="title">{article.data.title}</Fragment>
            <Fragment slot="description">{article.data.description}</Fragment>

            <TagList slot="tags" items={article.data.tags ?? []} />

            <CardCta slot="cta" href={article.data.url} text="Read on blog" external />
          </Card>
        ))}
      </div>
    ) : (
      <Typography tagName="p" class="empty-state">No articles published yet.</Typography>
    )}

    <Pagination 
      currentPage={currentPage} 
      totalPages={totalPages} 
      baseUrl="/writing" 
    />
  </main>
</BaseLayout>
