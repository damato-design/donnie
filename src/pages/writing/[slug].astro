---
/**
 * Article Detail Page
 * 
 * Dynamic route that displays a full article with MDX content support, table of contents,
 * metadata, and structured data for SEO. Provides an optimized reading experience with
 * clean typography and responsive design.
 * 
 * Features:
 * - MDX content rendering with full markdown support
 * - Automatic table of contents generation (when 3+ sections)
 * - Reading time calculation
 * - Article metadata (publish date, updated date, tags)
 * - Structured data for search engines
 * - Scroll-to-top functionality
 * - Back navigation to articles list
 * - Responsive typography
 * 
 * Route: /writing/[slug]
 * 
 * @page
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import StructuredData from '../../components/StructuredData.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import BackLink from '../../components/BackLink.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';
import { formatLongDate } from '../../utils/formatDate';
import Label from '../../components/Label.astro';
import Typography from '../../components/Typography.astro';
import { mdxComponents } from '../../components/mdxComponents';

/**
 * Generates static paths for all published articles
 * 
 * Queries the writing collection and filters for published articles only
 * (draft: false), creating a route for each article using its ID as the slug.
 * 
 * @returns Array of path objects with params
 */
export async function getStaticPaths() {
  const articles = await getCollection('writing', ({ data }) => {
    return data.draft === false;
  });
  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const { slug } = Astro.params;

/**
 * Retrieves the specific article entry by slug
 * 
 * Redirects to 404 if the article is not found.
 */
const article = await getEntry('writing', slug!);

if (!article) {
  return Astro.redirect('/404');
}

/**
 * Renders the article content and extracts headings
 * 
 * The Content component renders the MDX, and headings are used for
 * the table of contents generation.
 */
const { Content, headings } = await render(article);

const {
  title,
  description,
  publishDate,
  updatedDate,
  tags,
} = article.data;

/**
 * Calculates reading time from the article body
 * 
 * Uses word count to estimate reading time in minutes.
 */
const readingTime = getReadingTime(article.body || '');
---

<BaseLayout>
  <SEO 
    slot="head"
    title={`${title} - Writing`}
    description={description}
    type="article"
    publishDate={publishDate}
    updatedDate={updatedDate}
  />

  <StructuredData
    type="Article"
    data={{
      title,
      description,
      publishDate,
      updatedDate,
      tags,
      url: Astro.url.href,
    }}
  />

  <main class="article">
    <!-- Article Header -->
    <header class="article-header">
      <Typography tagName="h1" size="4xl">{title}</Typography>
      <div class="article-meta">
        <time class="publish-date" datetime={publishDate.toISOString()}>
          {formatLongDate(publishDate)}
        </time>
        <Typography tagName="span" class="meta-separator">·</Typography>
        <Typography tagName="span" class="reading-time">{readingTime}</Typography>
        {updatedDate && (
          <>
            <Typography tagName="span" class="meta-separator">·</Typography>
            <time class="updated-date" datetime={updatedDate.toISOString()}>
              Updated {formatLongDate(updatedDate)}
            </time>
          </>
        )}
      </div>
      {tags && tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <Label>{tag}</Label>
          ))}
        </div>
      )}
    </header>

    <!-- Table of Contents (conditionally rendered if 3+ sections) -->
    <TableOfContents headings={headings} />

    <!-- Article Content -->
    <article class="article-content">
      <Content components={mdxComponents} />
    </article>

    <BackLink href="/writing" text="All articles" />
  </main>

  <ScrollToTop />

  <style>
    .article {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .article-header {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--color-border);
    }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9375rem;
      color: var(--color-text-secondary);
      margin-bottom: 1rem;
    }

    .meta-separator {
      opacity: 0.5;
    }

    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .article-content {
      font-size: 1.125rem;
      line-height: 1.7;
      color: var(--color-text);
    }

    /* Text typography (headings, paragraphs, lists, links, ...) comes from the
       global base in typography.css plus <Typography prose> via mdxComponents.
       Only content-presentation with no global equivalent stays here. */
    .article-content :global(blockquote) {
      margin: 2rem 0;
      padding: 1rem 1.5rem;
      border-left: 4px solid var(--color-accent);
      background: var(--color-bg-secondary);
      font-style: italic;
      color: var(--color-text-secondary);
    }

    .article-content :global(pre) {
      margin: 2rem 0;
      padding: 1.5rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      overflow-x: auto;
    }

    .article-content :global(pre code) {
      background: none;
      padding: 0;
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    .article-content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 2rem 0;
    }

  </style>
</BaseLayout>
