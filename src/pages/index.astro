---
/**
 * Home Page
 * 
 * Case-study-first portfolio homepage that immediately showcases real impact and outcomes
 * rather than generic taglines. Features a hero section with featured project snapshots,
 * recent decisions, testimonials, and clear calls-to-action.
 * 
 * Design Philosophy:
 * - Lead with tangible results and case studies
 * - Document decision-making process transparently
 * - Demonstrate value through real project outcomes
 * - Provide multiple entry points (projects, decisions, journey)
 * 
 * Sections:
 * 1. Hero - Value statement with featured case study snapshots
 * 2. Introduction - Brief personal introduction with journey link
 * 3. Recent Decisions - Latest architectural/technical decisions
 * 4. Testimonials - Social proof from colleagues and clients
 * 5. Thinking - Problems and topics of interest
 * 6. CTA - Call-to-action for work opportunities
 * 
 * Features:
 * - Featured projects showcase (top 2-3)
 * - Recent decisions preview (top 2)
 * - Testimonials integration
 * - Structured data for SEO (WebSite and Person)
 * - Responsive grid layout
 * - Multiple CTAs for different user intents
 * 
 * Route: /
 * 
 * @page
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import SEO from '@components/SEO.astro';
import StructuredData from '@components/StructuredData.astro';
import ForwardLink from '@components/ForwardLink.astro';
import Testimonials from '@components/Testimonials.astro';
import Hero from '@components/Hero.astro';
import PageHeader from '@components/PageHeader.astro';
import Media from '@components/Media.astro';
import Card from '@components/Card.astro';
import CardList from '@components/CardList.astro';
import ButtonGroup from '@components/ButtonGroup.astro';
import TagList from '@components/TagList.astro';
import Button from '@components/Button.astro';
import Typography from '@components/Typography.astro';
import { getCollection } from 'astro:content';
import { formatMonthYear } from '@utils/formatDate';
import { truncate } from '@utils/cards';
import { siteConfig } from '../config';

/**
 * Queries recent decisions for preview section
 * 
 * Retrieves all decisions, sorts by date (newest first), and limits to
 * top 2 for the homepage preview.
 */
const allDecisions = await getCollection('decisions');
const recentDecisions = allDecisions
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);
---

<BaseLayout>
  <SEO 
    slot="head"
    title={`${siteConfig.author.name} - ${siteConfig.author.title}`}
    description={siteConfig.description}
    type="website"
    noSuffix
  />

  <!-- Structured Data for Homepage -->
  <StructuredData type="WebSite" />
  <StructuredData type="Person" />
    <!-- CASE-FIRST HERO -->
    <Hero>
      <Typography tagName="h1">Donnie <br/> D'Amato</Typography>
      <Typography>Design systems where design and code work beautifully together.</Typography>
      <ButtonGroup>
        <Button href="/projects" variant="primary">Explore Case Studies</Button>
        <Button href="/decisions" variant="secondary">How I Make Decisions</Button>
      </ButtonGroup>
      <Media slot="aside" src="/donnie.png" alt={`Portrait of ${siteConfig.author.name}`} />
    </Hero>

    <!-- Introduction -->
    <PageHeader>
      <Typography tagName="p">
        Hey, I'm {siteConfig.author.name}, a {siteConfig.author.title.toLowerCase()} with a background in UX design, front-end engineering, and higher education. I build systems that aren't just component libraries, they're strategic frameworks that turn chaos into cohesion.
      </Typography>
      <Typography tagName="p">
        Every major decision is documented, because the best design systems don't just scale products, they scale people too.
      </Typography>
      <ForwardLink href="/journey" text="Read my journey" />
    </PageHeader>

    <!-- Recent Decisions -->
    <section class="recent-decisions">
      <div class="section-header">
        <Typography tagName="h2">Recent Decisions</Typography>
        <ForwardLink href="/decisions" text="View all" />
      </div>
      
      <CardList compact empty="No decisions documented yet.">
        {recentDecisions.map((decision) => (
          <li>
            <Card>
              <Fragment slot="meta">{formatMonthYear(decision.data.date)}</Fragment>
              <Fragment slot="title">{decision.data.title}</Fragment>
              <Fragment slot="description">{truncate(decision.data.context, 180)}</Fragment>

              <TagList slot="tags" items={decision.data.tags ?? []} />

              <ButtonGroup slot="cta">
                <Button href={`/decisions/${decision.id}`} variant="secondary" size="sm" arrow>Read decision</Button>
              </ButtonGroup>
            </Card>
          </li>
        ))}
      </CardList>
    </section>

    <!-- Testimonials -->
    <Testimonials limit={3} />

    <!-- What I Think About -->
    <section class="thinking">
      <Typography tagName="h2">Problems I Enjoy Solving</Typography>
      <Typography>
        Allowing expression without breaking consistency · Giving designers and engineers the same language · Theming at scale across brands, locales, and accessibility needs · Bounded, semantic token systems over sprawling primitives · Working with the web's native layout instead of against it · Standardizing the vocabulary of design tokens · Bridging the gap between design and code · Scaling people, not just products
      </Typography>
    </section>

    <!-- CTA -->
    <section class="cta">
      <Typography tagName="h2">Let's Work Together</Typography>
      <Typography>
        Looking for design systems leadership, theming and token architecture, or someone who documents their thinking and shares it openly? Let's talk.
      </Typography>
      <ButtonGroup>
        <Button href="/projects" variant="primary">View My Work</Button>
        <Button href="/contact" variant="secondary">Get in Touch</Button>
      </ButtonGroup>
    </section>
</BaseLayout>
