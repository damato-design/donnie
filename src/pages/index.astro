---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import PageIntro from '@components/PageIntro.astro';
const tagline = 'Experience Architect';
---

<Layout>
    <Hero>{ tagline }</Hero>
    <PageIntro
        image="/images/donnie.jpg"
        tagline='Defining how experiences get built, taught, and shipped.'>
        I'm Donnie D'Amato, an Experience Architect working at the intersection of design, engineering, and education. My work spans building systems at scale, writing about token architecture, and teaching the next generation of user-centric builders.
    </PageIntro>
    <Hero cloned>{ tagline }</Hero>
</Layout>
