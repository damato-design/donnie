---
/**
 * Home Page
 * 
 * Case-study-first portfolio homepage that immediately showcases real impact and outcomes
 * rather than generic taglines. Features a hero section, a decisions preview, testimonials,
 * and clear calls-to-action.
 * 
 * Design Philosophy:
 * - Lead with tangible results and case studies
 * - Document decision-making process transparently
 * - Demonstrate value through real project outcomes
 * - Provide multiple entry points (projects, decisions, journey)
 * 
 * Sections:
 * 1. Hero - Value statement with portrait
 * 2. Introduction - Brief personal introduction with journey link
 * 3. Decisions - A preview of architectural/technical decisions
 * 4. Testimonials - Social proof from colleagues and clients
 * 5. Thinking - Problems and topics of interest
 * 6. CTA - Call-to-action for work opportunities
 *
 * Features:
 * - Decisions preview (first 2)
 * - Testimonials integration
 * - Structured data for SEO (WebSite and Person)
 * - Responsive grid layout
 * - Multiple CTAs for different user intents
 * 
 * Route: /
 * 
 * @page
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import SEO from '@components/SEO.astro';
import StructuredData from '@components/StructuredData.astro';
import ForwardLink from '@components/ForwardLink.astro';
// import Testimonials from '@components/Testimonials.astro';
import Hero from '@components/Hero.astro';
import PageHeader from '@components/PageHeader.astro';
import Media from '@components/Media.astro';
import Card from '@components/Card.astro';
import CardList from '@components/CardList.astro';
import ButtonGroup from '@components/ButtonGroup.astro';
import TagList from '@components/TagList.astro';
import Button from '@components/Button.astro';
import Typography from '@components/Typography.astro';
import { getCollection } from 'astro:content';
import { truncate } from '@utils/cards';
import { siteConfig } from '../config';
import portrait from '../assets/donnie.png';

/**
 * Queries decisions for the homepage preview section
 *
 * Retrieves all decisions and limits to the first 2 for the preview.
 */
const allDecisions = await getCollection('decisions');
const recentDecisions = allDecisions.slice(0, 2);
---

<BaseLayout>
  <SEO 
    slot="head"
    title={`${siteConfig.author.name} - ${siteConfig.author.title}`}
    description={siteConfig.description}
    type="website"
    noSuffix
  />

  <!-- Structured Data for Homepage -->
  <StructuredData type="WebSite" />
  <StructuredData type="Person" />
    <!-- CASE-FIRST HERO -->
    <Hero>
      <Typography tagName="h1">Donnie <br/> D'Amato</Typography>
      <Typography>UX Architect improving design systems and AI behavior.</Typography>
      <ButtonGroup>
        <Button href="/projects" variant="primary">Explore my work</Button>
        <Button href="/decisions" variant="secondary">Follow my thinking</Button>
      </ButtonGroup>
      <Media slot="aside" src={portrait.src} alt={`Portrait of ${siteConfig.author.name}`} />
    </Hero>

    <!-- Introduction -->
    <PageHeader>
      <Typography tagName="p">
        Hey, I'm {siteConfig.author.name}, a {siteConfig.author.title.toLowerCase()} with a background spanning design, front-end engineering, and higher education. For over a decade I've worked across the design systems practice, from token architecture and governance to the strategic frameworks that bring coherence at scale. Now I'm bringing that same discipline to a new frontier: shaping how AI behaves with the rigor we expect from a best in class interface.
      </Typography>
    </PageHeader>

    <!-- Decisions -->
    <section class="recent-decisions">
      <div class="section-header">
        <Typography tagName="h2">Decisions</Typography>
        <ForwardLink href="/decisions" text="View all" />
      </div>
      
      <CardList compact empty="No decisions documented yet.">
        {recentDecisions.map((decision) => (
          <li>
            <Card>
              <Fragment slot="title">{decision.data.title}</Fragment>
              <Fragment slot="description">{truncate(decision.data.context, 180)}</Fragment>

              <TagList slot="tags" items={decision.data.tags ?? []} />

              <ButtonGroup slot="cta">
                <Button href={`/decisions/${decision.id}`} variant="secondary" arrow>Read decision</Button>
              </ButtonGroup>
            </Card>
          </li>
        ))}
      </CardList>
    </section>

    <!-- Testimonials -->
    <!-- <Testimonials limit={3} /> -->

    <!-- What I Think About -->
    <section class="thinking">
      <Typography tagName="h2">Problems I Enjoy Solving</Typography>
      <ul>
        <Typography tagName='li'>Allowing expression without breaking consistency</Typography>
        <Typography tagName='li'>Giving designers, engineers, and now models the same language</Typography>
        <Typography tagName='li'>Designing how AI behaves predictably without flattening it</Typography>
        <Typography tagName='li'>Theming at scale across brands, locales, and accessibility needs</Typography>
        <Typography tagName='li'>Bounded, semantic token systems over sprawling primitives</Typography>
        <Typography tagName='li'>Bringing systems thinking to a new medium</Typography>
        <Typography tagName='li'>Bridging the gap between design and code</Typography>
        <Typography tagName='li'>Teaching the next people to do this work</Typography>
        <Typography tagName='li'>Scaling people, not just products</Typography>
      </ul>
    </section>

    <!-- CTA -->
    <section class="cta">
      <Typography tagName="h2">Let's Work Together</Typography>
      <Typography>
        Looking for user experience leadership, design systems and token architecture, guidance on designing how AI behaves, or someone who documents their thinking and shares it openly? Let's talk.
      </Typography>
      <ButtonGroup>
        <Button href="/projects" variant="primary">View My Work</Button>
        <Button href="/contact" variant="secondary">Get in Touch</Button>
      </ButtonGroup>
    </section>
</BaseLayout>
