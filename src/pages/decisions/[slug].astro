---
/**
 * Decision Detail Page
 * 
 * Dynamic route that displays the full decision record for a specific decision entry.
 * Presents a structured view of the decision-making process including context, the
 * decision made, alternatives considered with pros/cons, reasoning, and optional
 * additional content.
 * 
 * Features:
 * - Static path generation for all decision entries
 * - Structured decision presentation (Context → Decision → Alternatives → Reasoning)
 * - Alternatives comparison with pros/cons lists
 * - Tag display
 * - Optional markdown body content
 * - SEO optimization with article type
 * - Scroll-to-top functionality
 * - Related content navigation
 * - Back navigation to decisions list
 * 
 * Route: /decisions/[slug]
 * 
 * @page
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import BackLink from '../../components/BackLink.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import Section from '../../components/Section.astro';
import Label from '../../components/Label.astro';
import Typography from '../../components/Typography.astro';
import { mdxComponents } from '../../components/mdxComponents';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { formatLongDate } from '../../utils/formatDate';

/**
 * Generates static paths for all decision entries
 * 
 * Queries the decisions content collection and creates a route for each entry
 * using the entry ID as the slug parameter.
 * 
 * @returns Array of path objects with params and props
 */
export const getStaticPaths: GetStaticPaths = async () => {
  const decisions = await getCollection('decisions');
  return decisions.map((decision) => ({
    params: { slug: decision.id },
    props: { decision },
  }));
};

type DecisionEntry = Awaited<ReturnType<typeof getCollection<'decisions'>>>[number];

interface Props {
  /** The decision entry from the content collection */
  decision: DecisionEntry;
}

const { decision } = Astro.props;
const { Content } = await render(decision);

const formattedDate = formatLongDate(decision.data.date);
---

<BaseLayout>
  <SEO 
    slot="head"
    title={`${decision.data.title} - Decision Record`}
    description={decision.data.context}
    type="article"
  />

  <main class="decision-page">
    <article class="decision-content">
      <header class="decision-header">
        <time class="decision-date" datetime={decision.data.date.toISOString()}>
          {formattedDate}
        </time>
        
        <Typography tagName="h1" size="3xl">{decision.data.title}</Typography>

        {decision.data.tags && decision.data.tags.length > 0 && (
          <div class="decision-tags">
            {decision.data.tags.map((tag) => (
              <Label>{tag}</Label>
            ))}
          </div>
        )}
      </header>

      <Section title="Context" class="decision-section" size="xs" variant="muted">
        <Typography tagName="p">{decision.data.context}</Typography>
      </Section>

      <Section title="Decision" class="decision-section decision-made" size="xs" variant="muted">
        <div class="decision-callout">
          <Typography tagName="p" variant="primary">{decision.data.decision}</Typography>
        </div>
      </Section>

      <Section title="Alternatives Considered" class="decision-section" size="xs" variant="muted">
        <div class="alternatives-list">
          {decision.data.alternatives.map((alt) => (
            <div class="alternative-item">
              <Typography tagName="h3" size="base" variant="primary">{alt.option}</Typography>
              <div class="alternative-details">
                {alt.pros && alt.pros.length > 0 && (
                  <div class="pros-cons">
                    <Typography tagName="span" size="xs" class="detail-label pros-label">Pros</Typography>
                    <ul class="detail-list">
                      {alt.pros.map((pro) => (
                        <li>{pro}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {alt.cons && alt.cons.length > 0 && (
                  <div class="pros-cons">
                    <Typography tagName="span" size="xs" class="detail-label cons-label">Cons</Typography>
                    <ul class="detail-list">
                      {alt.cons.map((con) => (
                        <li>{con}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </Section>

      <Section title="Reasoning" class="decision-section" size="xs" variant="muted">
        <Typography tagName="p">{decision.data.reasoning}</Typography>
      </Section>

      {decision.body && decision.body.trim().length > 0 && (
        <section class="decision-body prose">
          <Content components={mdxComponents} />
        </section>
      )}

      <RelatedContent 
        relatedProjects={decision.data.relatedProjects} 
        relatedDecisions={decision.data.relatedDecisions} 
      />

      <BackLink href="/decisions" text="All decisions" />
    </article>
  </main>

  <ScrollToTop />

  <style>
    .decision-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .decision-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .decision-header {
      padding-bottom: 2rem;
    }

    .decision-date {
      display: block;
      font-size: 0.875rem;
      color: var(--color-text-muted);
      margin-bottom: 0.75rem;
    }

    .decision-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .decision-content :global(.decision-section) {
      padding-bottom: 1.5rem;
    }

    .decision-callout {
      padding: 1rem 1.25rem;
      background: var(--color-bg-secondary);
      border-left: 3px solid var(--color-accent);
      border-radius: 0 6px 6px 0;
    }

    .alternatives-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .alternative-item {
      padding: 1.25rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 8px;
    }

    .alternative-details {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .pros-cons {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .pros-label {
      color: #22c55e;
    }

    .cons-label {
      color: #ef4444;
    }

    .detail-list {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 0.875rem;
      line-height: 1.6;
      color: var(--color-text-secondary);
    }

    .detail-list li {
      position: relative;
      padding-left: 1rem;
      margin-bottom: 0.375rem;
    }

    .detail-list li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--color-text-muted);
    }

    .decision-body {
      padding-top: 1rem;
    }

    .decision-body.prose :global(code) {
      font-size: 0.9em;
      padding: 0.2em 0.4em;
      background: var(--color-bg-secondary);
      border-radius: 4px;
    }

    .decision-body.prose :global(pre) {
      padding: 1.25rem;
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      overflow-x: auto;
      margin-bottom: 1.5rem;
    }

    .decision-body.prose :global(pre code) {
      padding: 0;
      background: none;
    }

  </style>
</BaseLayout>
