---
/**
 * BaseCard Component
 *
 * Foundation component providing consistent styling and structure for all card types.
 * Use specialized cards (ArticleCard, ProjectCard, DecisionCard, TalkCard) rather than
 * this directly.
 *
 * The card itself is NOT a link. For accessibility, the only interactive element is the
 * forward link rendered at the bottom (from `href` + `ctaText`). This avoids wrapping a
 * whole block of content, including headings and tags, in a single anchor.
 *
 * The meta / title / description wrappers are only rendered when their slot is filled,
 * so the card can also be used purely as a styled shell (e.g. TalkCard) by passing
 * custom markup in the default slot and omitting `href`/`ctaText`.
 *
 * @component
 *
 * @slot badge - Optional badge/label at top (e.g., "Featured")
 * @slot meta - Metadata line (date, role, category, etc.)
 * @slot title - Card heading/title
 * @slot description - Card description or summary text
 * @slot tags - Container for tag list
 * @slot default - Additional content above the CTA
 *
 * @example
 * ```astro
 * <BaseCard href="/example" ctaText="Read more">
 *   <Fragment slot="meta">January 2024</Fragment>
 *   <Fragment slot="title">Card Title</Fragment>
 *   <Fragment slot="description">Card description text</Fragment>
 * </BaseCard>
 * ```
 */

import Button from '@components/Button.astro';
import Typography from '@components/Typography.astro';

interface Props {
  /** Destination for the card's forward link. Omit for a CTA-less shell. */
  href?: string;
  /** Text for the forward link. Required (with href) to render the CTA. */
  ctaText?: string;
  /** Additional CSS classes to apply to the card */
  class?: string;
}

const { href, ctaText, class: className } = Astro.props;

const hasMeta = Astro.slots.has('meta');
const hasTitle = Astro.slots.has('title');
const hasDescription = Astro.slots.has('description');
const showCta = href && ctaText;
---

<article class:list={['card', className]}>
  <slot name="badge" />
  {hasMeta && <Typography tagName="span" size="xs" variant="muted" class="card-meta"><slot name="meta" /></Typography>}
  {hasTitle && <Typography tagName="span" size="lg" variant="primary" class="card-title"><slot name="title" /></Typography>}
  {hasDescription && <Typography tagName="span" size="sm" variant="secondary" class="card-description"><slot name="description" /></Typography>}
  <slot name="tags" />
  <slot />
  {showCta && (
    <Button href={href} variant="secondary" size="sm" class="card-cta">
      {ctaText}
      <svg class="card-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M15.7071 5.29289C15.3166 4.90237 14.6834 4.90237 14.2929 5.29289C13.9024 5.68342 13.9024 6.31658 14.2929 6.70711L18.5858 11L3 11C2.44772 11 2 11.4477 2 12C2 12.5523 2.44772 13 3 13L18.5858 13L14.2929 17.2929C13.9024 17.6834 13.9024 18.3166 14.2929 18.7071C14.6834 19.0976 15.3166 19.0976 15.7071 18.7071L21.7071 12.7071C22.0976 12.3166 22.0976 11.6834 21.7071 11.2929L15.7071 5.29289Z"/>
      </svg>
    </Button>
  )}
</article>

<style>
  /* Card CTA renders via the Button primitive; slide the arrow on card hover
     (preserving the affordance the previous arrow-link had). */
  .card-cta-arrow {
    transition: transform 0.2s ease;
  }

  .card:hover .card-cta-arrow {
    transform: translateX(3px);
  }
</style>
