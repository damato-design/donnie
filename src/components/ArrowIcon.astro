---
/**
 * ArrowIcon Component
 *
 * Inline arrow SVG shared by the site's directional navigation affordances
 * (ForwardLink, CardCta, BackLink) so each one doesn't carry its own copy of
 * the path. Pass `class` to attach the consumer's animation/sizing hook.
 *
 * @component
 *
 * @example
 * ```astro
 * <ArrowIcon class="arrow-icon" />
 * <ArrowIcon direction="left" class="back-icon" />
 * ```
 */

interface Props {
  /** Arrow direction (default: 'right') */
  direction?: 'left' | 'right';
  /** Width/height of the rendered SVG in px (default: 16) */
  size?: number;
  /** Class applied to the <svg> (animation/sizing hook) */
  class?: string;
}

const { direction = 'right', size = 16, class: className } = Astro.props;

const paths = {
  right:
    'M15.7071 5.29289C15.3166 4.90237 14.6834 4.90237 14.2929 5.29289C13.9024 5.68342 13.9024 6.31658 14.2929 6.70711L18.5858 11L3 11C2.44772 11 2 11.4477 2 12C2 12.5523 2.44772 13 3 13L18.5858 13L14.2929 17.2929C13.9024 17.6834 13.9024 18.3166 14.2929 18.7071C14.6834 19.0976 15.3166 19.0976 15.7071 18.7071L21.7071 12.7071C22.0976 12.3166 22.0976 11.6834 21.7071 11.2929L15.7071 5.29289Z',
  left:
    'M9.70711 17.2929C10.0976 17.6834 10.0976 18.3166 9.70711 18.7071C9.31658 19.0976 8.68342 19.0976 8.29289 18.7071L2.29289 12.7071C1.90237 12.3166 1.90237 11.6834 2.29289 11.2929L8.29289 5.29289C8.68342 4.90237 9.31658 4.90237 9.70711 5.29289C10.0976 5.68342 10.0976 6.31658 9.70711 6.70711L5.41421 11L21 11C21.5523 11 22 11.4477 22 12C22 12.5523 21.5523 13 21 13L5.41422 13L9.70711 17.2929Z',
};
---

<svg
  class:list={[className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path d={paths[direction]} />
</svg>
