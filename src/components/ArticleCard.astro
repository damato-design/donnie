---
/**
 * ArticleCard Component
 *
 * Displays a blog/writing entry in a card format with metadata, title, description, and tags.
 * Extends BaseCard with article-specific formatting. Articles live on the blog, so the card
 * links out to the full post on blog.damato.design.
 *
 * @component
 *
 * @example
 * ```astro
 * <ArticleCard
 *   title="Getting Started with Astro"
 *   href="https://blog.damato.design/posts/getting-started-astro"
 *   description="Learn how to build fast websites with Astro"
 *   publishDate={new Date('2024-01-15')}
 *   tags={['astro', 'web-development', 'tutorial']}
 * />
 * ```
 */

import BaseCard from '@components/BaseCard.astro';
import TagList from '@components/TagList.astro';
import { formatLongDate } from '@utils/formatDate';

interface Props {
  /** Article title (displayed as card heading) */
  title: string;

  /** Full URL to the article on the blog */
  href: string;

  /** Brief description or excerpt of the article */
  description: string;

  /** Publication date (formatted as "Month Day, Year") */
  publishDate: Date;

  /** Optional array of tags/categories for the article */
  tags?: string[];
}

const { title, href, description, publishDate, tags = [] } = Astro.props;
---

<BaseCard href={href} external ctaText="Read on blog" class="article-card">
  <Fragment slot="meta">{formatLongDate(publishDate)}</Fragment>
  <Fragment slot="title">{title}</Fragment>
  <Fragment slot="description">{description}</Fragment>

  <TagList slot="tags" items={tags} />
</BaseCard>
