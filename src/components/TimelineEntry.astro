---
/**
 * TimelineEntry Component
 * 
 * Displays a single entry in a journey/career timeline with visual indicators, metadata,
 * and optional expandable content. Features a vertical timeline design with color-coded
 * dots and type badges to distinguish between milestones, learning experiences, and transitions.
 * 
 * Each entry can include:
 * - Date and type indicator
 * - Title and description
 * - Skills/technologies list
 * - Expandable detailed content (via slot)
 * 
 * @component
 * 
 * @slot default - Optional detailed content shown when expanded (supports markdown/prose)
 * 
 * @example
 * ```astro
 * <!-- Simple timeline entry without expandable content -->
 * <TimelineEntry
 *   date={new Date('2024-01-15')}
 *   title="Launched New Product"
 *   type="milestone"
 *   description="Successfully launched the redesigned platform to 10k users"
 *   skills={['React', 'TypeScript', 'AWS']}
 * />
 * 
 * <!-- Timeline entry with expandable content -->
 * <TimelineEntry
 *   date={new Date('2023-06-01')}
 *   title="Joined Tech Company"
 *   type="transition"
 *   description="Started as Senior Frontend Developer"
 *   skills={['Vue.js', 'Node.js']}
 *   hasContent={true}
 * >
 *   <p>Detailed information about the role and achievements...</p>
 * </TimelineEntry>
 * ```
 */

import Card from '@components/Card.astro';
import Label from '@components/Label.astro';
import TagList from '@components/TagList.astro';
import { formatMonthYear } from '@utils/formatDate';
import { timelineTypeLabels, timelineTypeColors } from '@utils/cards';

interface Props {
  /** Date of the timeline event (formatted as "Month Year") */
  date: Date;
  
  /** Title/heading of the timeline entry */
  title: string;
  
  /** Type of entry (determines color coding and badge label) */
  type: 'milestone' | 'learning' | 'transition';
  
  /** Brief description of the event or achievement */
  description: string;
  
  /** Optional array of skills or technologies associated with this entry */
  skills?: string[];
  
  /** Whether this entry has expandable content in the slot (default: false) */
  hasContent?: boolean;
}

const { date, title, type, description, skills, hasContent = false } = Astro.props;

const formattedDate = formatMonthYear(date);
---

<article class="timeline-entry">
  <div class="timeline-marker">
    <div class="timeline-dot" data-type={type}></div>
    <div class="timeline-line"></div>
  </div>
  
  <div class="timeline-content">
    <Card>
      <div slot="badge" class="timeline-header">
        <time class="timeline-date" datetime={date.toISOString()}>
          {formattedDate}
        </time>
        <Label color={timelineTypeColors[type]} uppercase>{timelineTypeLabels[type]}</Label>
      </div>

      <Fragment slot="title">{title}</Fragment>
      <Fragment slot="description">{description}</Fragment>

      {skills && skills.length > 0 && (
        <div slot="tags" class="timeline-skills">
          <span class="skills-label">Skills:</span>
          <TagList items={skills} />
        </div>
      )}

      {hasContent && (
        <details class="timeline-disclosure">
          <summary class="expand-toggle">
            <span class="expand-text"></span>
            <svg class="expand-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="timeline-body-content prose">
            <slot />
          </div>
        </details>
      )}
    </Card>
  </div>
</article>

<style>

  .timeline-entry {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 1.5rem;
    position: relative;
  }

  .timeline-entry:last-child .timeline-line {
    display: none;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .timeline-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid var(--color-bg);
    position: relative;
    flex-shrink: 0;
  }

  .timeline-dot[data-type="milestone"] {
    background: var(--color-accent);
  }

  .timeline-dot[data-type="learning"] {
    background: #10b981;
  }

  .timeline-dot[data-type="transition"] {
    background: #f59e0b;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background: currentColor;
    margin-top: 0.5rem;
  }

  .timeline-content {
    padding-bottom: 3rem;
  }

  .timeline-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .timeline-skills {
    margin-top: 1rem;
  }

  .skills-label {
    display: block;
    margin-bottom: 0.5rem;
  }

  .expand-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1rem;
    padding: 0.5rem 0;
    background: none;
    border: none;
    font-size: 0.875rem;
    
    color: var(--color-accent);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .expand-toggle:hover {
    opacity: 0.8;
  }

  .expand-icon {
    transition: transform 0.2s ease;
  }

  .expand-text::before {
    content: "Read more";
  }

  .timeline-disclosure[open] .expand-text::before {
    content: "Show less";
  }

  .timeline-disclosure[open] .expand-icon {
    transform: rotate(180deg);
  }

  .timeline-body-content.prose {
    padding-top: 1.5rem;
    border-top: 1px solid currentColor;
    margin-top: 1rem;
  }

</style>
