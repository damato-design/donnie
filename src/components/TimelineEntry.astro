---
/**
 * TimelineEntry Component
 * 
 * Displays a single entry in a journey/career timeline with visual indicators, metadata,
 * and optional expandable content. Features a vertical timeline design with color-coded
 * dots and type badges to distinguish between milestones, learning experiences, and transitions.
 * 
 * Each entry can include:
 * - Date and type indicator
 * - Title and description
 * - Skills/technologies list
 * - Expandable detailed content (via slot)
 * 
 * @component
 * 
 * @slot default - Optional detailed content shown when expanded (supports markdown/prose)
 * 
 * @example
 * ```astro
 * <!-- Simple timeline entry without expandable content -->
 * <TimelineEntry
 *   date={new Date('2024-01-15')}
 *   title="Launched New Product"
 *   type="milestone"
 *   description="Successfully launched the redesigned platform to 10k users"
 *   skills={['React', 'TypeScript', 'AWS']}
 * />
 * 
 * <!-- Timeline entry with expandable content (the disclosure auto-hides when empty) -->
 * <TimelineEntry
 *   date={new Date('2023-06-01')}
 *   title="Joined Tech Company"
 *   type="transition"
 *   description="Started as Senior Frontend Developer"
 *   skills={['Vue.js', 'Node.js']}
 * >
 *   <p>Detailed information about the role and achievements...</p>
 * </TimelineEntry>
 * ```
 */

import Card from '@components/Card.astro';
import Disclosure from '@components/Disclosure.astro';
import TagList from '@components/TagList.astro';
import { formatMonthYear } from '@utils/formatDate';

interface Props {
  /** Date of the timeline event (formatted as "Month Year") */
  date: Date;
  
  /** Title/heading of the timeline entry */
  title: string;
  
  /** Type of entry (determines color coding and badge label) */
  type: 'milestone' | 'learning' | 'transition';
  
  /** Brief description of the event or achievement */
  description: string;
  
  /** Optional array of skills or technologies associated with this entry */
  skills?: string[];
}

const { date, title, type, description, skills } = Astro.props;

const formattedDate = formatMonthYear(date);
---

<article class="timeline-entry">
  <div class="timeline-marker">
    <div class="timeline-dot" data-type={type}></div>
    <div class="timeline-line"></div>
  </div>
  
  <div class="timeline-content">
    <Card>
      <Fragment slot="meta">{formattedDate}</Fragment>
      <Fragment slot="title">{title}</Fragment>
      <Fragment slot="description">{description}</Fragment>
      <TagList slot="tags" items={skills ?? []} />

      <Disclosure>
        <slot />
      </Disclosure>
    </Card>
  </div>
</article>

<style>

  .timeline-entry {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 1.5rem;
    position: relative;
  }

  .timeline-entry:last-child .timeline-line {
    display: none;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .timeline-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--color-accent);
    border: 3px solid var(--color-bg);
    position: relative;
    flex-shrink: 0;
  }

  .timeline-dot[data-type="milestone"] {
    background: var(--color-accent);
  }

  .timeline-dot[data-type="learning"] {
    background: #10b981;
  }

  .timeline-dot[data-type="transition"] {
    background: #f59e0b;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background: currentColor;
    margin-top: 0.5rem;
  }

</style>
