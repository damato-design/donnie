---
/**
 * TagList Component
 *
 * Renders a horizontal, wrapping list of tags as shared Label primitives, so
 * tags match every other badge. Centralizes the `tags.map(...)` markup repeated
 * across the cards.
 *
 * When `max` is set and there are more items than `max`, the overflow collapses
 * into a "+N" label. Renders nothing when `items` is empty.
 *
 * Only the list layout is styled here; the label look comes from Label.
 *
 * @component
 *
 * @example
 * ```astro
 * <TagList items={tags} />
 * <TagList items={techStack} max={4} slot="tags" />
 * ```
 */

import Label from '@components/Label.astro';

interface Props {
  /** Tag labels to display */
  items: string[];
  /** Optional cap; items beyond this collapse into a "+N" pill */
  max?: number;
}

const { items, max } = Astro.props;

const visible = typeof max === 'number' ? items.slice(0, max) : items;
const overflow = typeof max === 'number' ? Math.max(items.length - max, 0) : 0;
---

{items.length > 0 && (
  <ul class="tags-list">
    {visible.map((item) => (
      <li><Label>{item}</Label></li>
    ))}
    {overflow > 0 && (
      <li><Label>+{overflow}</Label></li>
    )}
  </ul>
)}

<style>
  .tags-list {
    list-style: none;
    margin: 0 0 1rem 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .tags-list li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Decorative separator between tags (was an aria-hidden span). */
  .tags-list li:not(:first-child)::before {
    content: "·";
    font-size: var(--font-size-xs);
  }

</style>
