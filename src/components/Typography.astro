---
/**
 * Typography
 *
 * Minimal editorial text primitive. Renders the chosen element via `tagName` and
 * applies the site's editorial highlight (`.inline`) to block-level text. It is
 * deliberately prop-free beyond `tagName`: no `class`, no attribute pass-through.
 *
 * If an element needs a class, an attribute (href, id, aria-*, ...), or any other
 * hook, author it as a plain HTML element instead of routing it through here.
 *
 * @component
 *
 * @slot default - The text content of the element.
 *
 * @example
 * ```astro
 * <Typography tagName="h2">Section title</Typography>
 * <Typography tagName="p">A paragraph.</Typography>
 * <Typography tagName="span">caption</Typography>
 * ```
 */

interface Props {
  /** The underlying HTML element. Defaults to `p`. */
  tagName?: keyof astroHTML.JSX.IntrinsicElements;
}

const { tagName = 'p' } = Astro.props;

const Tag = tagName as any;
const blockElements = ['p', 'h2', 'h3', 'h4', 'h5', 'h6', 'li', 'blockquote'];
const shouldWrap = blockElements.includes(Tag);
---

<Tag>
    {shouldWrap ? <span class="inline"><slot /></span> : <slot />}
</Tag>

<style>
  :where(h1, h2, h3) {
    font-family: "BBH Hegarty", sans-serif;
    font-weight: normal;
    text-wrap: balance;
  }

  h1 {
    filter: url('#longshadow');
    transform: skewY(-4deg);
    color: oklch(from var(--bgcolor) calc(l + .05) c h);
    pointer-events: none;
    line-height: 1;
    padding-block-end: 32px;
    margin-block: 0;
    font-size: clamp(2.5rem, 1.5rem + 5vw, 10rem);
  }

  .inline {
    background: oklch(from var(--bgcolor) calc(l + .05) c h);
    padding: .25lh .5em;
    line-height: 1.7;
    box-decoration-break: clone;
  }

  h2:has(.inline) {
    margin: 0;
    padding-block: 1rem;
    filter: url(#longshadow);
  }

  :where(p, li) {
    text-wrap: pretty;
    max-width: 45ch;
  }
</style>
