---
/**
 * Typography
 *
 * Polymorphic editorial text primitive. Renders any element via `tagName` while
 * applying the site's editorial typography, and lets visual size be chosen
 * independently of the semantic element via the `size` prop.
 *
 * Design notes:
 * - The *base* element styles (heading scale, paragraph rhythm, lists,
 *   blockquotes, tables, ...) live in the always-loaded global stylesheet
 *   (`src/styles/typography.css`) so bare HTML and MDX both render correctly.
 *   This component owns the pieces that only make sense as an API: the
 *   decoupled `size` scale and the *prose-context* rules (flow spacing on
 *   headings, underlined accent links) that were previously duplicated across
 *   the article/case-study pages.
 * - Use it at the lowest level: each text element is its own <Typography>. For
 *   `<li><a>…</a></li>`, the `<a>` is the component, not the `<li>`.
 * - For MDX/markdown prose you cannot hand-wrap elements; route them through the
 *   shared map in `mdxComponents.ts` via `<Content components={...} />`, which
 *   renders each element as a <Typography prose> at any nesting depth.
 *
 * @component
 *
 * @slot default - The text content of the element.
 *
 * @example
 * ```astro
 * <Typography tagName="h2" size="4xl">Section title</Typography>
 * <Typography tagName="h3" size="xl">Looks like an h3, ranks like an h3</Typography>
 * <Typography tagName="p" prose size="lg">Lead-in paragraph.</Typography>
 * <Typography tagName="span" size="sm">caption</Typography>
 * ```
 */

/** Font-size scale keys, mirroring the `--font-size-*` tokens. */
export type TypographySize =
  | 'xs' | 'sm' | 'base' | 'lg' | 'xl' | '2xl' | '3xl' | '4xl' | '5xl';

interface Props {
  /** The underlying HTML element. Defaults to `p`. */
  tagName?: keyof astroHTML.JSX.IntrinsicElements;
  /** Visual size, decoupled from the element. Omit to use the element default. */
  size?: TypographySize;
  /** Any other valid attributes for the chosen element (href, datetime, id, ...). */
  [key: string]: unknown;
}

const {
  tagName = 'p',
  size,
  ...rest
} = Astro.props;

const Tag = tagName as any;
const blockElements = ['p', 'h2', 'h3', 'h4', 'h5', 'h6', 'li'];
const shouldWrap = blockElements.includes(Tag);
---

<Tag
  data-size={size}
  {...rest}
>
    {shouldWrap ? <span class="inline"><slot /></span> : <slot />}
</Tag>

<style>
  .inline {
    background: var(--color-bg-elevated);
    padding: .25lh .5em;
    line-height: 1.7;
    box-decoration-break: clone;
  }

  h2:has(.inline) {
    margin: 0;
    padding-block: 1rem;
    filter: url(#longshadow);
  }

  /* Decoupled size scale: set only when `size` is passed, otherwise the element
     keeps its default size from the global stylesheet. */
  [data-size="xs"]   { font-size: var(--font-size-xs); }
  [data-size="sm"]   { font-size: var(--font-size-sm); }
  [data-size="base"] { font-size: var(--font-size-base); }
  [data-size="lg"]   { font-size: var(--font-size-lg); }
  [data-size="xl"]   { font-size: var(--font-size-xl); }
  [data-size="2xl"]  { font-size: var(--font-size-2xl); }
  [data-size="3xl"]  { font-size: var(--font-size-3xl); }
  [data-size="4xl"]  { font-size: var(--font-size-4xl); }
  [data-size="5xl"]  { font-size: var(--font-size-5xl); }

  /* Prose flow context: top spacing between sections (headings have no
     top-margin by default so they stay usable in UI). */
  h2.t-prose {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
  }

  h3.t-prose {
    margin-top: var(--space-2xl);
  }

  h4.t-prose {
    margin-top: var(--space-xl);
  }

  h5.t-prose,
  h6.t-prose {
    margin-top: var(--space-lg);
  }

  :where(p, li) {
    text-wrap: pretty;
    max-width: 45ch;
  }

  /* Prose links read as content links (underlined accent), unlike the bare
     navigation/button anchors styled globally. */
  a.t-prose {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: all 0.2s ease;
  }

  code.t-prose {
    font-size: var(--font-size-sm);
  }
</style>
