---
/**
 * Section Component
 *
 * Structural wrapper for a titled content section: a `<section class="section">`
 * with a heading followed by slotted content. Standardizes the markup repeated
 * across the case study page and the decision page.
 *
 * The heading renders through <Typography>. Per-page spacing hooks onto the
 * component-owned `.section` class from the page's own scoped styles (e.g.
 * `.case-study :global(.section)`), so there is no consumer-supplied class.
 *
 * @component
 *
 * @slot default - The section body content
 *
 * @example
 * ```astro
 * <Section title="Overview">
 *   <Typography tagName="p">{overview}</Typography>
 * </Section>
 *
 * <Section title="Context">
 *   <Typography tagName="p">{context}</Typography>
 * </Section>
 * ```
 */

import Typography from '@components/Typography.astro';

interface Props {
  /** Heading text */
  title?: string;
}

const { title } = Astro.props;
---

<section class="section">
  { title && <Typography tagName="h2">{title}</Typography> }
  <slot />
</section>

<style is:global>
  .section {
    & > :where(p, ul, blockquote) {
      font-size: 1.2em;
    }

    &:not(:has(h2)) {
      margin-block: 32px;
      background: var(--color-bg-elevated);
      border: 1px solid;
      padding: 32px;

      & > :first-child {
        margin-block-start: 0;
      }

      & > :last-child {
        margin-block-end: 0;
      }
    }
  }
</style>
