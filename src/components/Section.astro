---
/**
 * Section Component
 *
 * Structural wrapper for a titled content section: a `<section>` with a heading
 * followed by slotted content. Standardizes the markup repeated across the case
 * study page (`.case-study-section`) and the decision page (`.decision-section`
 * + `.section-label`).
 *
 * The heading renders through <Typography>; callers control its appearance with
 * the `size` and `variant` props (e.g. a large case-study heading vs. a small
 * decision eyebrow) rather than with their own scoped CSS.
 *
 * @component
 *
 * @slot default - The section body content
 *
 * @example
 * ```astro
 * <Section title="Overview" class="case-study-section">
 *   <Typography tagName="p" prose>{overview}</Typography>
 * </Section>
 *
 * <Section title="Context" class="decision-section" size="xs">
 *   <Typography tagName="p">{context}</Typography>
 * </Section>
 * ```
 */

import Typography from '@components/Typography.astro';
import type { TypographySize } from '@components/Typography.astro';

interface Props {
  /** Heading text */
  title: string;
  /** Class(es) for the <section> wrapper */
  class?: string;
  /** Heading size, decoupled from the h2 element. */
  size?: TypographySize;
  /** Heading colour/emphasis variant. */
  variant?: 'lead' | 'secondary' | 'primary';
}

const { title, class: className, size, variant } = Astro.props;
---

<section class:list={[className]}>
  <Typography tagName="h2" size={size} variant={variant}>{title}</Typography>
  <slot />
</section>
