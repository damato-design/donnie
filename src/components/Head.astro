---
import metadata from "../metadata.json";
const { title = metadata.title, description = metadata.description } =
    Astro.props;
const ogImage = new URL("og-image.png", Astro.url);

const schema = {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    dateCreated: "2020-05-07T12:34:00-05:00",
    dateModified: new Date().toISOString(),
    mainEntity: {
        "@id": "#main-author",
        "@type": "Person",
        name: "Donnie D'Amato",
        alternateName: "donniedamato",
        description,
        image: "http://donnie.damato.design/images/donnie.jpg",
        sameAs: [
            "https://twitter.com/donniedamato",
            "https://linkedin.com/in/fauxserious",
            "https://github.com/fauxserious",
            "https://social.design.systems/@donnie",
            "https://bsky.app/profile/donnie.damato.design",
            "https://adplist.org/mentors/donnie-damato",
            "https://www.threads.net/@donniedamato",
        ],
    },
};
---

<head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5" />
    <meta name="msapplication-TileColor" content="#b91d47" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@donniedamato" />
    <meta name="twitter:creator:id" content="230538553" />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style is:global>
        @font-face {
            font-family: "Mother";
            font-style: normal;
            font-weight: 400;
            src:
                local("Mother"),
                url("/Mother-Regular.woff2") format("woff2");
        }

        @font-face {
            font-family: "Daeling";
            font-style: normal;
            font-weight: 400;
            src:
                local("Daeling"),
                url("/Daeling-Regular.woff2") format("woff2");
        }

        @font-face {
            font-family: "Kentish";
            font-style: normal;
            font-weight: 400;
            src:
                local("Kentish"),
                url("/Kentish-Regular.woff2") format("woff2");
        }

        *,
        :before,
        :after {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            overscroll-behavior-y: none;
            text-rendering: optimizeLegibility;
            font-family: system-ui;
            line-height: 1.5;
            background-color: #002515;
            background-attachment: fixed;
            background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg"><filter id="crush"><feTurbulence type="fractalNoise" baseFrequency="0.015" numOctaves="5" stitchTiles="stitch" result="noise"/><feColorMatrix in="noise" type="saturate" values="0" result="destat"/><feComponentTransfer in="destat" result="contrast"><feFuncR type="linear" slope="2" intercept="-0.5"/><feFuncG type="linear" slope="2" intercept="-0.5"/><feFuncB type="linear" slope="2" intercept="-0.5"/></feComponentTransfer></filter><rect width="100%" height="100%" filter="url(%23crush)" opacity="0.4" fill="white"/></svg>');
            background-blend-mode: overlay;
            color: white;
        }

        a {
            color: inherit;
        }

        :where(h1, h2, h3) {
            font-family: "Kentish";
            font-weight: normal;
            margin: 0;
            padding-block: 0.5ex;
            background: linear-gradient(
                110deg,
                #bf953f 0%,
                /* Rich warm gold */ #fcf6ba 20%,
                /* Bright champagne */ #b38728 40%,
                /* Honey gold mid-tone */ #fcf6ba 50%,
                /* Central glint */ #bf953f 65%,
                /* Warm gold */ #fcf6ba 85%,
                /* Finishing highlight */ #aa771c 100% /* Soft bronze edge */
            );

            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            filter: url(#realistic-gold)
                drop-shadow(2px 3px 5px rgba(0, 0, 0, 0.4));

            /* 3. The "Sheen" Layer */
            /* A very faint, bright stroke gives the thin parts of Kentish a metallic edge */
            -webkit-text-stroke: 0.3px rgba(255, 252, 224, 0.4);
        }

        h2 {
            font-size: 3.5rem;
        }
    </style>
</head>
