---
/**
 * ScrollToTop Component
 * 
 * Floating button that appears in the bottom-right corner when the user scrolls down
 * past a threshold (300px). Clicking the button smoothly scrolls back to the top of
 * the page. The button fades in/out with a slide animation for a polished UX.
 * 
 * Features:
 * - Auto-shows/hides based on scroll position
 * - Smooth scroll animation
 * - Accessible with keyboard focus and ARIA labels
 * - Works with Astro View Transitions
 * 
 * @component
 * 
 * @example
 * ```astro
 * <ScrollToTop />
 * ```
 */

import Button from '@components/Button.astro';
---

<Button
  variant="secondary"
  id="scroll-to-top"
  aria-label="Scroll to top"
  title="Scroll to top"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</Button>

<style>
  /* Icon-only FAB: reshapes the Button primitive into a fixed, square control.
     The id selector wins specificity over the .btn base rules. */
  button#scroll-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 44px;
    height: 44px;
    padding: 0;
    background: var(--color-bg-elevated);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition:
      opacity 0.2s ease,
      visibility 0.2s ease,
      transform 0.2s ease,
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
    z-index: 50;
  }

  button#scroll-to-top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  button#scroll-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

</style>

<script>
  function initScrollToTop() {
    const button = document.querySelector('#scroll-to-top');
    if (!button) return;

    const SCROLL_THRESHOLD = 300;

    function toggleVisibility() {
      if (!button) return;
      if (window.scrollY > SCROLL_THRESHOLD) {
        button.classList.add('is-visible');
      } else {
        button.classList.remove('is-visible');
      }
    }

    function scrollToTop() {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    }

    window.addEventListener('scroll', toggleVisibility, { passive: true });
    button.addEventListener('click', scrollToTop);

    // Initial check
    toggleVisibility();
  }

  // Run on initial load
  initScrollToTop();

  // Re-run on Astro page transitions
  document.addEventListener('astro:after-swap', initScrollToTop);
</script>
