---
/**
 * Alternatives Component
 *
 * Renders each alternative option considered for a decision record as its own
 * two-column table with three rows:
 *   1. the option name, merged across both columns
 *   2. the "Pros" / "Cons" column headers
 *   3. the pros and cons lists
 *
 * @component
 *
 * @example
 * ```astro
 * <Alternatives alternatives={[
 *   { option: "Build it ourselves", pros: ["Full control"], cons: ["Slower"] },
 *   { option: "Buy a vendor solution", pros: ["Fast"], cons: ["Lock-in"] }
 * ]} />
 * ```
 */

import ProsConsList from '@components/ProsConsList.astro';

interface Alternative {
  /** The alternative option's name */
  option: string;

  /** Arguments in favour of this option */
  pros?: string[];

  /** Arguments against this option */
  cons?: string[];
}

interface Props {
  /** The alternatives considered for the decision */
  alternatives: Alternative[];
}

const { alternatives } = Astro.props;
---

<ul class="alternatives-list">
  {alternatives.map((alt) => (
    <li>
      <table class="alternative-table">
        <tbody>
          <tr>
            <th colspan="2" scope="colgroup" class="option-cell">{alt.option}</th>
          </tr>
          <tr>
            <th scope="col" class="col-pros">Pros</th>
            <th scope="col" class="col-cons">Cons</th>
          </tr>
          <tr>
            <td><ProsConsList items={alt.pros} /></td>
            <td><ProsConsList items={alt.cons} /></td>
          </tr>
        </tbody>
      </table>
    </li>
  ))}
</ul>

<style>
  .alternatives-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .alternative-table {
    width: 100%;
    text-align: left;
    border-collapse: collapse;
    background: var(--color-bg-elevated);
    border: 1px solid;
  }

  .alternative-table th,
  .alternative-table td {
    width: 50%;
    padding: 0.75rem 1rem;
    vertical-align: top;
    border: 1px solid currentColor;
  }

  .option-cell {
    font-size: 1rem;
  }

  .col-pros,
  .col-cons {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .col-pros {
    color: #22c55e;
  }

  .col-cons {
    color: #ef4444;
  }
</style>
