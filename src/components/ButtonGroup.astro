---
/**
 * ButtonGroup
 *
 * The layout wrapper for placing one or two action buttons together: a flex row
 * that gives its buttons a consistent gap and wraps on narrow viewports. Reach
 * for it wherever a `<Button>` (or two) is dropped into the page: hero CTAs,
 * section CTAs, a card's `cta` slot, the 404 home link, etc. It owns only the
 * grouping/layout; the buttons themselves are composed as slotted children, so
 * each picks its own `variant`/`arrow`.
 *
 * @component
 * @slot default - The button(s) to lay out (one or two `<Button>`s).
 *
 * @example
 * ```astro
 * <ButtonGroup>
 *   <Button href="/projects" variant="primary">View My Work</Button>
 *   <Button href="/contact" variant="secondary">Get in Touch</Button>
 * </ButtonGroup>
 *
 * <Card>
 *   ...
 *   <ButtonGroup slot="cta">
 *     <Button href="/projects/x" variant="secondary" arrow>View case study</Button>
 *   </ButtonGroup>
 * </Card>
 * ```
 */
---

<div class="button-group">
  <slot />
</div>

<style>
  .button-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
</style>
