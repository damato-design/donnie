---
/**
 * Footer Component
 * 
 * Site-wide footer displaying copyright information and social media links.
 * Automatically filters and displays only configured social links from site config.
 * Responsive layout that stacks vertically on mobile devices.
 * 
 * Social links are pulled from siteConfig.social and only displayed if they have
 * a URL value configured. Links open in new tabs with proper security attributes.
 * 
 * @component
 * 
 * @example
 * ```astro
 * <Footer />
 * ```
 */
import { siteConfig } from '../config';
import Typography from '@components/Typography.astro';

/**
 * Gets the current year for copyright display
 */
const currentYear = new Date().getFullYear();

/**
 * Filters and formats social links from site configuration
 * 
 * Only includes platforms that have a URL configured (non-empty values).
 * Capitalizes platform names for display (e.g., "github" becomes "Github").
 * 
 * @returns Array of social link objects with platform name and URL
 */
const socialLinks = Object.entries(siteConfig.social)
  .filter(([_, url]) => url)
  .map(([platform, url]) => ({
    platform: platform.charAt(0).toUpperCase() + platform.slice(1),
    url
  }));
---

<footer class="site-footer">
  <div class="footer-container">
    <Typography tagName="span">© {currentYear} {siteConfig.author.name}</Typography>
    
    {socialLinks.length > 0 && (
      <ul class="footer-social">
        {socialLinks.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.platform}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-elevated);
    border-top: 1px solid currentColor;
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-social li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Decorative separator between social links (was an inline span). */
  .footer-social li:not(:first-child)::before {
    content: "·";
    opacity: 0.5;
    user-select: none;
  }

  .footer-social a {
    font-size: 0.8125rem;
    
    transition: color 0.2s ease;
  }

</style>
