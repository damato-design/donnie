---
/**
 * Navigation Component
 * 
 * Main site navigation with responsive behavior and theme toggle. Features centered
 * navigation on desktop and horizontal scrolling on mobile. The theme toggle is fixed
 * at the right edge with a gradient fade effect.
 * 
 * Navigation items are configured in src/config.ts and automatically include a "Home"
 * link at the beginning. Active page highlighting is determined server-side from
 * Astro.url.pathname.
 * 
 * @component
 * 
 * @example
 * ```astro
 * <Navigation />
 * ```
 */
import { siteConfig } from '../config';

const currentPath = Astro.url.pathname;

/**
 * Navigation items with Home prepended
 * 
 * Combines a hardcoded Home link with navigation items from site config
 * to ensure Home is always first in the navigation.
 */
const navItems = [
  { label: 'Home', href: '/' },
  ...siteConfig.nav,
];

/**
 * Determines if a navigation item should be marked as active
 * 
 * Home link is only active on the exact root path. Other links are active
 * if the current path starts with their href, allowing child pages to
 * highlight their parent navigation item.
 * 
 * @param href - The navigation item's URL
 * @returns True if the navigation item should be marked as active
 */
const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-scroll">
    <ul class="nav-list">
      {navItems.map((item) => (
        <li class="nav-item">
          <a 
            href={item.href} 
            class="nav-link"
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    background: oklch(from var(--bgcolor) calc(l + .05) c h);
  }

  .nav-scroll {
    flex: 1;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    max-width: min(800px, 100%);
    margin: 0 auto;
    padding: 0 16px;
  }

  .nav-scroll::-webkit-scrollbar {
    display: none;
  }

  .nav-list {
    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    list-style: none;
    margin: 0;
    padding: 0;
    letter-spacing: 2px;
    min-width: max-content;
  }

  .nav-item {
    flex-shrink: 0;
    margin: 0;
  }

  .nav-link {
    white-space: nowrap;
    display: inline-flex;
    padding: 16px;
    background: oklch(from var(--bgcolor) calc(l + .05) c h);
    color: currentColor;
  }

  .nav-link[aria-current="page"] {
    background-color: currentColor;
    span {
      color: var(--bgcolor);
    }
  }
</style>
