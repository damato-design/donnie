---
/**
 * Hero
 *
 * Reusable two-column hero / promo banner. It owns only the layout shell: a
 * value statement on the left (the default slot) and supporting content on the
 * right (the `aside` slot). Both columns are authored by the caller, so any
 * markup is allowed (headings, copy, CTAs, cards, embeds, images, forms, ...).
 * When the `aside` slot is empty the hero collapses to a single column.
 *
 * Author the left column with the editorial primitives (<Typography>, <Button>)
 * and the right column with one or more <HeroCard slot="aside"> for the common
 * promo/snapshot card; the right column stacks its children vertically.
 *
 * Used as the homepage banner and as a promotional banner on secondary pages
 * (e.g. promoting the Mise en Mode book, the Wireframe show, or Cal.com booking).
 *
 * @component
 *
 * @slot default - Left-column value statement (heading, copy, CTAs).
 * @slot aside - Right-column content. When empty, the hero is single-column.
 *
 * @example
 * ```astro
 * <Hero compact>
 *   <Typography tagName="h2">Now in print: <em>Mise en Mode</em></Typography>
 *   <HeroCard slot="aside" label="Book" title="Mise en Mode" href="https://mode.place" external />
 * </Hero>
 * ```
 */

interface Props {
  /** Reduce vertical padding (for use below a page header) */
  compact?: boolean;
  /** Show the bottom divider/border (default true) */
  divider?: boolean;
}

const { compact = false, divider = true } = Astro.props;

/** Whether custom right-column content was provided */
const hasAside = Astro.slots.has('aside');
---

<section class:list={['hero', { 'hero--compact': compact, 'hero--no-divider': !divider }]}>
  <div class:list={['hero-grid', { 'hero-grid--single': !hasAside }]}>
    <div class="hero-left">
      <slot />
    </div>

    {hasAside && (
      <div class="hero-right">
        <slot name="aside" />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0 5rem;
    border-bottom: 1px solid currentColor;
    margin-bottom: 4rem;
  }

  .hero--compact {
    padding: 0.5rem 0 2.5rem;
    margin-bottom: 2.5rem;
  }

  .hero--no-divider {
    border-bottom: none;
    margin-bottom: 2rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .hero-grid--single {
    grid-template-columns: 1fr;
  }

  .hero-left {
    padding-right: 2rem;
  }

  .hero-grid--single .hero-left {
    padding-right: 0;
    max-width: 640px;
  }

  /* Call-authored CTA row in the left column. `:global` reaches across the slot
     boundary, since slotted markup is owned by the parent, not this component. */
  .hero-left :global(.hero-cta) {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  /* Right column: stacks slotted content (e.g. multiple <HeroCard>) vertically */
  .hero-right {
    padding-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

</style>
