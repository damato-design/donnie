---
/**
 * Hero
 *
 * Reusable two-column hero / promo banner. It owns only the layout shell: a
 * value statement on the left (the default slot) and supporting content on the
 * right (the `aside` slot). Both columns are authored by the caller, so any
 * markup is allowed (headings, copy, CTAs, cards, embeds, images, forms, ...).
 * When the `aside` slot is empty the hero collapses to a single column.
 *
 * Author the left column with the editorial primitives (<Typography>, <Button>)
 * and the right column with whatever supporting content fits; the right column
 * stacks its children vertically.
 *
 * Used as the homepage banner and as a promotional banner on secondary pages
 * (e.g. promoting the Mise en Mode book, the Wireframe show, or Cal.com booking).
 *
 * @component
 *
 * @slot default - Left-column value statement (heading, copy, CTAs).
 * @slot aside - Right-column content. When empty, the hero is single-column.
 *
 * @example
 * ```astro
 * <Hero>
 *   <Typography tagName="h2">Now in print: <em>Mise en Mode</em></Typography>
 *   <Media slot="aside" src="/cover.png" alt="Book cover" />
 * </Hero>
 * ```
 */

interface Props {}

/** Whether custom right-column content was provided */
const hasAside = Astro.slots.has("aside");
import Blob from '@assets/blob.svg';

/** Randomize the blob's rotation so each render sits at a slightly different angle */
const blobRotate = `${Math.round(Math.random() * 360)}deg`;

---

<section class="hero" style={`--blob-rotate: ${blobRotate}`}>
  <Blob/>

  {
    hasAside && (
      <div class="hero-media">
        <slot name="aside" />
      </div>
    )
  }

  <div class="hero-content">
    <slot />
  </div>
</section>

<style>
  .hero {
    margin-block: 32px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    align-items: center;
    font-size: 1.4em;

    & svg {
      grid-column: 1 / -1;
      grid-row: 1;
      rotate: var(--blob-rotate);
      aspect-ratio: 2;
      width: 100%;
      overflow: hidden;
      scale: 2;
    }
  }

  .hero-content {
    grid-column: 1 / -3;
    grid-row: 1;
    isolation: isolate;
  }

  .hero-media {
    grid-row: 1;
    grid-column: 2 / -1;
    display: flex;
    justify-content: end;
    isolation: isolate;

    & :where(img, video) {
      border-radius: 16% 84% 12% 88% / 83% 26% 74% 17%;
    }
  }

  @media (max-width: 600px) {
    .hero-content {
      grid-column: 1 / -1;
    }

    .hero-media {
      display: none;
    }
  }
</style>
