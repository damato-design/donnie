---
/**
 * HeroCard
 *
 * A clickable promo / snapshot card intended for use inside the Hero `aside`
 * slot (the Hero right column stacks multiple cards vertically). Encapsulates
 * the card markup and styles so it can be reused without the Hero component
 * owning a `cards` prop.
 *
 * @component
 *
 * @example
 * ```astro
 * <HeroCard slot="aside" label="Book" title="Mise en Mode" href="https://mode.place" external />
 * ```
 */
interface Props {
  /** Small eyebrow label (e.g. "Book", "Case · Lead") */
  label?: string;
  /** Card title */
  title: string;
  /** Supporting description */
  description?: string;
  /** Link target */
  href: string;
  /** Open in a new tab (external links) */
  external?: boolean;
}

const { label, title, description, href, external = false } = Astro.props;
const ext = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={href} class="hero-card" {...ext}>
  {label && <span class="hero-card-label">{label}</span>}
  <span class="hero-card-title">{title}</span>
  {description && <span class="hero-card-desc">{description}</span>}
</a>

<style>
  .hero-card {
    display: block;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .hero-card:hover {
    border-color: var(--color-text-muted);
    background: var(--color-bg-elevated);
  }

  .hero-card-label {
    display: block;
    font-size: 0.6875rem;
    
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.375rem;
  }

  .hero-card-title {
    display: block;
    font-size: 1rem;
    
    color: var(--color-text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .hero-card-desc {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

</style>
