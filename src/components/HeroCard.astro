---
/**
 * HeroCard
 *
 * A clickable promo / snapshot card intended for use inside the Hero `aside`
 * slot (the Hero right column stacks multiple cards vertically). Encapsulates
 * the card markup and styles so it can be reused without the Hero component
 * owning a `cards` prop.
 *
 * @component
 *
 * @example
 * ```astro
 * <HeroCard slot="aside" label="Book" title="Mise en Mode" href="https://mode.place" external />
 * ```
 */
import Typography from '@components/Typography.astro';

interface Props {
  /** Small eyebrow label (e.g. "Book", "Case · Lead") */
  label?: string;
  /** Card title */
  title: string;
  /** Supporting description */
  description?: string;
  /** Link target */
  href: string;
  /** Open in a new tab (external links) */
  external?: boolean;
}

const { label, title, description, href, external = false } = Astro.props;
const ext = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={href} class="hero-card" {...ext}>
  {label && <Typography tagName="span" size="xs" variant="muted" class="hero-card-label">{label}</Typography>}
  <Typography tagName="span" variant="primary" class="hero-card-title">{title}</Typography>
  {description && <Typography tagName="span" size="sm" variant="secondary" class="hero-card-desc">{description}</Typography>}
</a>

<style>
  .hero-card {
    display: block;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-elevated);
    text-decoration: none;
  }

  .hero-card-label {
    display: block;
    margin-bottom: 0.375rem;
  }

  .hero-card-title {
    display: block;
    margin-bottom: 0.5rem;
  }

  .hero-card-desc {
    display: block;
  }

</style>
