---
/**
 * CardCta Component
 *
 * The standard forward call-to-action for a Card: a secondary Button with a
 * trailing arrow that slides on card hover. Pass it into a Card's `cta` slot so
 * every card's CTA looks and behaves the same without the card itself being a
 * link.
 *
 * @component
 *
 * @example
 * ```astro
 * <Card>
 *   ...
 *   <CardCta slot="cta" href="/projects/x" text="View case study" />
 * </Card>
 * ```
 */

import Button from '@components/Button.astro';
import ArrowIcon from '@components/ArrowIcon.astro';

interface Props {
  /** Destination for the CTA link */
  href: string;
  /** CTA label text */
  text: string;
  /** Open in a new tab (off-site destinations) */
  external?: boolean;
}

const { href, text, external = false } = Astro.props;
---

<Button href={href} external={external} variant="secondary" size="sm">
  {text}
  <ArrowIcon />
</Button>
