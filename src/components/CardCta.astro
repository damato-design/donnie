---
/**
 * CardCta Component
 *
 * The standard forward call-to-action for a Card: a secondary Button with a
 * trailing arrow that slides on card hover. Pass it into a Card's `cta` slot so
 * every card's CTA looks and behaves the same without the card itself being a
 * link.
 *
 * @component
 *
 * @example
 * ```astro
 * <Card>
 *   ...
 *   <CardCta slot="cta" href="/projects/x" text="View case study" />
 * </Card>
 * ```
 */

import Button from '@components/Button.astro';

interface Props {
  /** Destination for the CTA link */
  href: string;
  /** CTA label text */
  text: string;
  /** Open in a new tab (off-site destinations) */
  external?: boolean;
}

const { href, text, external = false } = Astro.props;
---

<Button href={href} external={external} variant="secondary" size="sm" class="card-cta">
  {text}
  <svg class="card-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path d="M15.7071 5.29289C15.3166 4.90237 14.6834 4.90237 14.2929 5.29289C13.9024 5.68342 13.9024 6.31658 14.2929 6.70711L18.5858 11L3 11C2.44772 11 2 11.4477 2 12C2 12.5523 2.44772 13 3 13L18.5858 13L14.2929 17.2929C13.9024 17.6834 13.9024 18.3166 14.2929 18.7071C14.6834 19.0976 15.3166 19.0976 15.7071 18.7071L21.7071 12.7071C22.0976 12.3166 22.0976 11.6834 21.7071 11.2929L15.7071 5.29289Z"/>
  </svg>
</Button>
