---
import MiseEnMode from '@assets/mise-en-mode.svg';
import Fan from '@assets/fan.svg';
import Badge from '@components/Badge.astro';
import Button from '@components/Button.astro';
const { tagline, link } = Astro.props;
---

<style>
    .book-section {
        background: linear-gradient(
                195deg,
                oklch(from var(--base) calc(l - 0.45) c h),
                oklch(from var(--base) calc(l - 0.6) c h) 60%
            );
    }

    .lockup {
        display: flex;
        padding-block: 64px;
        align-items: center;
        gap: 32px;
    }

    .title {
        font-size: 2em;
    }

    .book-callout {
        aspect-ratio: .6;
        border-radius: 100% / 30%;
        corner-shape: bevel;
        border: 5px double var(--border);
        text-align: center;
        flex: 1 0 30%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        filter: drop-shadow(
                    12px 30px oklch(from var(--base) calc(l - 0.72) c h)
                );
        --s: 20px;
                --c1: oklch(from var(--base) calc(l - 0.6) c h);
                --c2: oklch(from var(--base) calc(l - 0.55) c h);

                background:
                    radial-gradient(
                        var(--c1) 14%,
                        var(--c2) 15% 30%,
                        var(--c1) 31% 44%,
                        var(--c2) 45% 60%,
                        #0000 61%
                    ),
                    linear-gradient(
                        45deg,
                        transparent 46%,
                        var(--c2) 0 54%,
                        transparent 0
                    ),
                    linear-gradient(
                            -45deg,
                            transparent 46%,
                            var(--c2) 0 54%,
                            transparent 0
                        )
                        var(--c1);
                background-size: var(--s) var(--s);
    }

    .fan {
        color: var(--border);
        width: 50%
    }

    .book-title {
        margin: 0;
        color: white;
        border: 1px solid var(--border);
        width: 80%;
        padding: 16px;
        position: relative;

        &::after {
            content: '';
            position: absolute;
            inset: -8px;
            border: 1px solid var(--border);
            border-radius: 16px;
            corner-shape: notch;
        }
    }

    .book-subtitle {
        background: linear-gradient(
                15deg,
                oklch(from var(--base) calc(l - 0.5) c h),
                oklch(from var(--base) calc(l - 0.6) c h) 60%
            );
        margin: 0;
        margin-block-start: 32px;
        padding: 16px 8px;
        font-size: .9em;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        align-self: stretch;
    }

</style>

<section class="book-section" data-navigation="Mise en Mode">
    <div class="lockup max-width">
        <div class="content">
            <Badge>Author</Badge>
            <div class="title">
                <h2>{tagline}</h2>
            </div>
            <div class="intro">
                <p><slot /></p>
                <Button href={link}>Buy the book</Button>
            </div>
        </div>
        <div class="book-callout">
            <Fan class="fan"/>
            <div class="book-title">
                <MiseEnMode/>
            </div>
            <p class="book-subtitle">A new model for design systems and customization</p>
            <Fan class="fan" style="rotate: 180deg"/>
        </div>
    </div>
</section>