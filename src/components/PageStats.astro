---
/**
 * PageStats Component
 * 
 * Displays count or statistics information in page headers, typically showing the total
 * number of items in a collection (e.g., "12 articles", "8 projects"). Used consistently
 * across all listing pages for a unified look.
 * 
 * @component
 * 
 * @example
 * ```astro
 * <PageStats text="24 articles" />
 * <PageStats text="12 projects" />
 * <PageStats text="Showing 1-10 of 45" />
 * ```
 */

import Typography from '@components/Typography.astro';

interface Props {
  /** Statistics text to display (e.g., "12 articles", "Showing 1-10 of 45") */
  text: string;
}

const { text } = Astro.props;
---

<Typography tagName="p" size="sm" variant="muted">{text}</Typography>
