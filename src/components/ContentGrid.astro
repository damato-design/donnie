---
const { gridWidth } = Astro.props;
---

<style define:vars={{ gridWidth }}>
    .content-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(var(--gridWidth, 260px), 1fr));
        gap: 15px;
        padding: 3rem;
    }
</style>

<div class="content-grid">
    <slot/>
</div>