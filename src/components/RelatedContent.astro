---
/**
 * RelatedContent Component
 * 
 * Displays related projects and decisions for cross-referencing content.
 * Fetches actual content data from slugs and renders compact cards.
 * 
 * @component
 * 
 * @example
 * ```astro
 * <RelatedContent 
 *   relatedProjects={['project-slug-1', 'project-slug-2']}
 *   relatedDecisions={['decision-slug-1']}
 * />
 * ```
 */

import { getCollection } from 'astro:content';
import { formatMonthShortYear } from '@utils/formatDate';
import Typography from '@components/Typography.astro';

interface Props {
  /** Array of project slugs to display */
  relatedProjects?: string[];
  
  /** Array of decision slugs to display */
  relatedDecisions?: string[];
  
  /** Section title (default: "Related") */
  title?: string;
}

const { 
  relatedProjects = [], 
  relatedDecisions = [],
  title = "Related"
} = Astro.props;

// Fetch all collections once
const allProjects = await getCollection('projects');
const allDecisions = await getCollection('decisions');

// Filter to get related items
const projects = relatedProjects
  .map(slug => allProjects.find(p => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);

const decisions = relatedDecisions
  .map(slug => allDecisions.find(d => d.id === slug))
  .filter((d): d is NonNullable<typeof d> => d !== undefined);

const hasRelated = projects.length > 0 || decisions.length > 0;
---

{hasRelated && (
  <aside class="related-content">
    <Typography tagName="h2">{title}</Typography>

    <div class="related-grid">
      {projects.length > 0 && (
        <div class="related-section">
          <Typography tagName="h3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
            Case Studies
          </Typography>
          <ul class="related-list">
            {projects.map((project) => (
              <li>
                <a href={`/projects/${project.id}`} class="related-item">
                  <span class="related-item-meta">{project.data.role} · {project.data.year}</span>
                  <span class="related-item-title">{project.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
      
      {decisions.length > 0 && (
        <div class="related-section">
          <Typography tagName="h3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            Decisions
          </Typography>
          <ul class="related-list">
            {decisions.map((decision) => (
              <li>
                <a href={`/decisions/${decision.id}`} class="related-item">
                  <span class="related-item-meta">{formatMonthShortYear(decision.data.date)}</span>
                  <span class="related-item-title">{decision.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </aside>
)}

<style>
  .related-content {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid currentColor;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-item {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--color-bg-elevated);
    border: 1px solid currentColor;
    
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .related-item-meta {
    display: block;
    margin-bottom: 0.25rem;
  }

  .related-item-title {
    display: block;
  }

</style>
